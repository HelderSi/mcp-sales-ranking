{
  "name": "mcp_ranking",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "server:dev": "tsx src/server.ts",
    "build": "tsc",
    "inspector:run:dev": "npx @modelcontextprotocol/inspector pnpm server:dev",
    "inspector:run:build": "pnpm build && npx @modelcontextprotocol/inspector node build/server.js",
    "inspector:run:config": "npx @modelcontextprotocol/inspector --config mcp.json --server mcp_ranking",
    "inspector:cli:list-tools": "npx @modelcontextprotocol/inspector --cli tsx src/server.ts --method tools/list",
    "inspector:cli:call-tool": "npx @modelcontextprotocol/inspector --cli tsx src/server.ts --method tools/call --tool-name get_top_sellers --input '{\"limit\": 3}'",
    "agent": "tsx src/sales-agent/index.ts"
  },
