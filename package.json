    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "dotenv": "^17.4.2",
    "openai": "^6.42.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
